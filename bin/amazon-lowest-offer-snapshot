#!/usr/bin/env bash
# Amazon lowest-offer daily snapshot — cron-friendly entry point.
#
# Runs: em-tools amazon coverage download-and-publish
# (sync AMZ seed files from GCS, query lowest_offer_listings_*_new, publish snapshot)
#
# Usage:
#   bin/amazon-lowest-offer-snapshot              # all default marketplaces
#   bin/amazon-lowest-offer-snapshot de us      # subset only
#
# Cron (set EM_TOOLS_BUNDLE when cron has no rbenv shims in PATH):
#   EM_TOOLS_BUNDLE=/home/Admin/.rbenv/shims/bundle \
#     /home/Admin/src/em-tools/bin/amazon-lowest-offer-snapshot \
#     >> /home/Admin/src/em-tools/log/em-tools.lowest-offer.log 2>&1

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

BUNDLE="${EM_TOOLS_BUNDLE:-${BUNDLE_BIN:-bundle}}"

mkdir -p log tmp

exec "$BUNDLE" exec bin/em-tools amazon coverage download-and-publish "$@"
