#!/usr/bin/env bash
# Daily 11ST price freshness snapshot: em_inventory (source=11ST) vs user1_kr_products (elevenst).
#
# Reads cluster URLs from .env (loaded by bin/em-tools). Example .env:
#   ELASTICSEARCH_URL='http://user:pw@34.44.148.50:80'
#   DATA_ELASTICSEARCH_URL='http://user:pw@34.16.105.219:9200'
#
# Usage:
#   bin/elevenst-price-freshness-snapshot
#   bin/elevenst-price-freshness-snapshot --threshold-days 14
#
# Cron (daily):
#   30 5 * * * sky bash -lc 'cd /home/sky/src/em-tools && bin/elevenst-price-freshness-snapshot \
#     >> log/elevenst-price-freshness.log 2>&1'

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

BUNDLE="${EM_TOOLS_BUNDLE:-${BUNDLE_BIN:-bundle}}"

mkdir -p log

exec "$BUNDLE" exec bin/em-tools kr elevenst publish-price-freshness-snapshot "$@"
