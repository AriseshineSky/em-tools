#!/usr/bin/env bash
# Incremental sync: user1_ebay_products (DATA_ELASTICSEARCH_URL) -> ebay_us_products (ELASTICSEARCH_URL).
#
# Reads cluster URLs from .env (loaded by bin/em-tools). Example .env:
#   ELASTICSEARCH_URL='http://user:pw@34.44.148.50:80'
#   DATA_ELASTICSEARCH_URL='http://user:pw@34.16.105.219:9200'
#
# Usage:
#   bin/ebay-sync-user1-products
#   bin/ebay-sync-user1-products --since-date 2026-05-18T14:45:15+00:00
#   bin/ebay-sync-user1-products --since-hours 6
#   bin/ebay-sync-user1-products -H 3
#   bin/ebay-sync-user1-products --full
#   bin/ebay-sync-user1-products --skip-missing
#   bin/ebay-sync-user1-products --dry-run
#
# Cron (hourly; dotenv loads .env when cwd is the repo):
#   0 * * * * sky bash -lc 'cd /home/sky/src/em-tools && bin/ebay-sync-user1-products \
#     >> log/ebay-sync-user1-products.log 2>&1'

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

BUNDLE="${EM_TOOLS_BUNDLE:-${BUNDLE_BIN:-bundle}}"

mkdir -p log

exec "$BUNDLE" exec bin/em-tools ebay products sync-user1 "$@"
