#!/usr/bin/env ruby
# frozen_string_literal: true

# Project console: boots em-tools and drops you into IRB with the gem and
# dotenv loaded. Useful for poking pipelines / clients ad hoc.
#
#   bundle exec bin/console

require "bundler/setup"

begin
  require "dotenv/load"
rescue LoadError
  # Optional in environments that inject env via systemd/cron.
end

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))
require "em_tools"

require "irb"
IRB.start(__FILE__)
