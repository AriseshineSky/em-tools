#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
begin
  require "dotenv/load"
rescue LoadError
end

require "json"
require "optparse"

require "em/tools"

def usage(parser)
  warn parser.help
  exit 1
end

def load_keywords(path)
  return [] unless path

  contents = File.read(path, encoding: "utf-8")
  if path.end_with?(".json")
    Array(JSON.parse(contents))
  else
    contents.lines.map(&:strip).reject(&:empty?)
  end
end

command = ARGV.shift

main_parser = OptionParser.new do |opts|
  opts.banner = <<~BANNER
    Usage:
      em-tools dump INDEX [options]
      em-tools import-products [options] INPUT_PATH

    Commands:
      dump             Stream Elasticsearch docs as NDJSON.
      import-products  Filter products and emit import batch plans as NDJSON.
  BANNER
end

usage(main_parser) unless ["dump", "import-products"].include?(command)

if command == "dump"
  options = {output_path: nil, batch_size: 1000}

  parser = OptionParser.new do |opts|
  opts.banner = <<~BANNER
    Usage: em-tools dump INDEX [options]

    Stream all documents from an Elasticsearch index as NDJSON (one hit JSON object per line).

    Set ELASTICSEARCH_URL (e.g. http://host:9200). Optional: create a .env file when using dotenv.

    Examples:
      em-tools dump ssg_products > ssg_products.ndjson
      em-tools dump ssg_products -o ssg_products.ndjson
  BANNER

    opts.on("-o", "--output PATH", "Write to file instead of stdout") {|path| options[:output_path] = path }
    opts.on("-b", "--batch-size N", Integer, "Documents per request (default: 1000)") {|n| options[:batch_size] = n }
  end

  parser.parse!(ARGV)
  index = ARGV.shift
  usage(parser) unless index && !index.start_with?("-")

  unless ARGV.empty?
    warn "error: unexpected arguments: #{ARGV.join(" ")}"
    usage(parser)
  end

  if ENV["ELASTICSEARCH_URL"].to_s.strip.empty?
    warn "error: ELASTICSEARCH_URL is not set"
    exit 1
  end

  client = Em::Tools::ElasticsearchClient.new
  out = options[:output_path] ? File.open(options[:output_path], "w") : $stdout

  begin
    client.iterate_all(index: index, batch_size: options[:batch_size]) do |hit|
      out.puts(JSON.generate(hit))
    end
  ensure
    out.close if options[:output_path]
  end
else
  options = {
    store_code: nil,
    min_price: 40,
    max_price: 500,
    batch_size: 50,
    min_shipping_days: 7,
    taxonomy_name: "Categories",
    merchant_id: nil,
    vendor_id: nil,
    tax_category_id: 1,
    stock_location_id: nil,
    shipping_category_id: nil,
    dont_filter_blacklist: false,
    dont_optimize_title: false,
    keywords_path: nil,
    output_path: nil
  }

  parser = OptionParser.new do |opts|
    opts.banner = <<~BANNER
      Usage: em-tools import-products [options] INPUT_PATH

      Read NDJSON products, filter invalid/blacklisted/price-ineligible items,
      and emit batch payloads as NDJSON.

      This first version preserves the import shape for a later Spree adapter.
    BANNER

    opts.on("-s", "--store-code CODE", String, "Store code, required.") {|value| options[:store_code] = value }
    opts.on("--keywords-path PATH", String, "Optional blacklist keywords file (txt or json).") {|value| options[:keywords_path] = value }
    opts.on("-o", "--output PATH", String, "Write batch payloads to file instead of stdout.") {|value| options[:output_path] = value }
    opts.on("-b", "--batch-size N", Integer, "Products per batch (default: 50).") {|value| options[:batch_size] = value }
    opts.on("--min-price N", Float, "Minimum product price (default: 40).") {|value| options[:min_price] = value }
    opts.on("--max-price N", Float, "Maximum product price (default: 500).") {|value| options[:max_price] = value }
    opts.on("--min-shipping-days N", Integer, "Minimum shipping days (default: 7).") {|value| options[:min_shipping_days] = value }
    opts.on("--taxonomy-name NAME", String, "Taxonomy name (default: Categories).") {|value| options[:taxonomy_name] = value }
    opts.on("--merchant-id ID", String, "Merchant id, preserved for later adapter.") {|value| options[:merchant_id] = value }
    opts.on("--vendor-id ID", String, "Vendor id, preserved for later adapter.") {|value| options[:vendor_id] = value }
    opts.on("--tax-category-id ID", Integer, "Tax category id (default: 1).") {|value| options[:tax_category_id] = value }
    opts.on("--stock-location-id ID", Integer, "Stock location id.") {|value| options[:stock_location_id] = value }
    opts.on("--shipping-category-id ID", Integer, "Shipping category id.") {|value| options[:shipping_category_id] = value }
    opts.on("--dont-filter-blacklist", "Disable blacklist filtering.") {options[:dont_filter_blacklist] = true }
    opts.on("--dont-optimize-title", "Preserve the title as-is.") {options[:dont_optimize_title] = true }
  end

  parser.parse!(ARGV)
  input_arg = ARGV.shift
  usage(parser) unless input_arg

  if !ARGV.empty?
    warn "error: unexpected arguments: #{ARGV.join(" ")}"
    usage(parser)
  end

  if options[:store_code].to_s.strip.empty?
    warn "error: --store-code is required"
    exit 1
  end

  input_path = File.expand_path(input_arg)
  unless File.file?(input_path)
    warn "error: input file not found: #{input_path}"
    exit 1
  end

  keywords = options[:keywords_path] ? load_keywords(options[:keywords_path]) : []
  out = options[:output_path] ? File.open(options[:output_path], "w") : $stdout
  importer = Em::Tools::Importers::ProductImporter.new(
    store_code: options[:store_code],
    batch_size: options[:batch_size],
    min_price: options[:min_price],
    max_price: options[:max_price],
    blacklist_keywords: keywords,
    min_shipping_days: options[:min_shipping_days],
    taxonomy_name: options[:taxonomy_name],
    merchant_id: options[:merchant_id],
    vendor_id: options[:vendor_id],
    tax_category_id: options[:tax_category_id],
    stock_location_id: options[:stock_location_id],
    shipping_category_id: options[:shipping_category_id],
    dont_filter_blacklist: options[:dont_filter_blacklist],
    dont_optimize_title: options[:dont_optimize_title]
  )

  begin
    result = importer.process(input_path, output: out)
    warn "[ProductAudit] Invalid: #{result.invalid_products}, CategoryFiltered: #{result.category_filtered_products}, PriceFiltered: #{result.price_filtered_products}, Blacklisted: #{result.blacklisted_products}, Accepted: #{result.accepted_products}, Batches: #{result.batches_emitted}"
  ensure
    out.close if options[:output_path]
  end
end
