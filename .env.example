# Copy to .env in the repo root. ALL secrets and real-cluster URLs live here.
# config/settings.yml only carries structure (routing tables, source lists, bucket names).
#
# em-tools is a project-local Ruby app, not a packaged gem; the CLI is at
# bin/em-tools and auto-loads this file via dotenv. Scheduled jobs source the
# same .env via systemd EnvironmentFile= (see schedule/systemd/) or an
# explicit `bash -lc` in cron (see schedule/cron.example).

# ============================================================================
# Application
# ============================================================================
APP_ENV=development                  # development | test | production (selects YAML section)

# ============================================================================
# Logging — EmTools::Core::Logger
# ============================================================================
# EM_TOOLS_LOG_LEVEL=info             # debug | info | warn | error | fatal
# EM_TOOLS_LOG_OUTPUT=stderr          # stderr | stdout | /absolute/path/to/em-tools.log
# EM_TOOLS_LOG_FORMAT=text            # text | json

# ============================================================================
# Elasticsearch — required for most ES tasks
# ============================================================================
# Primary cluster (everything except lotteon export). Auth either embedded in URL
# (http://user:pass@host:9200) or via the username/password/api_key vars below.
ELASTICSEARCH_URL=http://localhost:9200

# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme
# ELASTICSEARCH_API_KEY=              # base64 id:key; if set, overrides user/password

# Second cluster (lotteon / analytics). Embed basic auth in URL.
# DATA_ELASTICSEARCH_URL=http://user:password@host:9200

# Generic per-cluster overrides. NAME is uppercased; cluster name from settings.yml.
# ELASTICSEARCH_CLUSTER_PRIMARY_URL=
# ELASTICSEARCH_CLUSTER_ANALYTICS_URL=

# `em-tools es-dump-index` targets ELASTICSEARCH_URL.
# `em-tools es-download-product` targets DATA_ELASTICSEARCH_URL.
# ES_DUMP_INDEX=user1_lotteon_products
# ES_DUMP_OUTPUT=tmp/dump.ndjson
# ES_DUMP_BATCH_SIZE=1000

# ============================================================================
# Google Cloud Storage — credentials never go in YAML
# ============================================================================
# Path to service account JSON key. Defaults to $HOME/.em_celery/gcs-sa.json when unset.
# GCS_SERVICE_ACCOUNT_PATH=/path/to/gcs-service-account.json

# Alternatively, embed the JSON content directly (takes precedence over path).
# GCS_CREDENTIALS=
# GCS_PROJECT_ID=

# Override default bucket / prefix for lowest-offer + ebay seed pulls
# GCS_BUCKET=em-bucket
# GCS_SEEDS_PREFIX=em-analytics

# ============================================================================
# Inventory sync — `em-tools inventory-sync` / `inventory-sync-from-gcs`
# ============================================================================
INVENTORY_INDEX=em_inventory          # ES index for em_inventory CSVs

# inventory-sync-from-gcs single-source debug:
# INVENTORY_GS_URI=gs://em-bucket/path.csv
# INVENTORY_GCS_BUCKET=em-bucket
# INVENTORY_GCS_OBJECT=path/to/file.csv
# INVENTORY_REFRESH=1                 # _refresh after bulk
# INVENTORY_PRUNE_OBSOLETE=1          # delete docs not seen this batch
# INVENTORY_FEED_ID=Boyner            # fallback inventory_feed when CSV has no Source col

# ============================================================================
# Google Ads catalog — `em-tools google-ads catalog sync` / `catalog sync-from-gcs`
# ============================================================================
# GOOGLE_ADS_CATALOG_INDEX=google_ads_products
# GOOGLE_ADS_CATALOG_GS_URI=gs://em-bucket/google-ads-catalog.csv
# GOOGLE_ADS_CATALOG_GCS_BUCKET=em-bucket
# GOOGLE_ADS_CATALOG_GCS_OBJECT=google-ads-catalog.csv
# GOOGLE_ADS_CATALOG_REFRESH=1
# GOOGLE_ADS_CATALOG_PRUNE_OBSOLETE=1   # delete docs not seen this batch (same feed field rules)
# GOOGLE_ADS_CATALOG_FEED_ID=google_ads_us
# GOOGLE_ADS_CATALOG_DROP_FIELDS=handle,variants

# ============================================================================
# Amazon lowest-offer snapshot — `em-tools lowest-offer-publish-snapshot` /
# `lowest-offer-download-and-publish`
# ============================================================================
# LOWEST_OFFER_ID_SOURCE=inventory    # inventory | seed (default seed)
# LOWEST_OFFER_SEED_DIR=tmp           # directory with amz_<mp>.txt files
# LOWEST_OFFER_SEEDS_FORCE_DOWNLOAD=1 # re-download GCS seeds even if local file exists
# LOWEST_OFFER_MARKETPLACES=us,ca     # default = 9 markets if unset
# LOWEST_OFFER_INVENTORY_INDEX=em_inventory
# LOWEST_OFFER_INVENTORY_PRODUCT_ID_FIELD=product_id.keyword
# LOWEST_OFFER_INVENTORY_AMAZON_SOURCES=AMZ_US,AMZ_CA,...
# LOWEST_OFFER_INVENTORY_MARKETPLACE_FIELD=
# LOWEST_OFFER_INVENTORY_MAX_HITS=
# LOWEST_OFFER_WRITE_MISSING_ASINS=true
# LOWEST_OFFER_MISSING_ASINS_DIR=tmp/lowest_offer_missing_asins
# MONITORING_LOWEST_OFFER_SNAPSHOT_INDEX=monitoring_lowest_offer_snapshots
# MONITORING_ES_INDEX_REFRESH=true

# ============================================================================
# eBay listings coverage — `em-tools ebay-listings-publish-snapshot`
# ============================================================================
EBAY_LISTINGS_COVERAGE_INVENTORY_INDEX=ebay_us_products
# EBAY_LISTINGS_COVERAGE_ID_SOURCE=inventory
# EBAY_LISTINGS_COVERAGE_SEED_FILE=
# EBAY_LISTINGS_COVERAGE_SEED_DIR=
# EBAY_LISTINGS_COVERAGE_MARKETPLACE=us
# EBAY_LISTINGS_COVERAGE_INDEX=ebay_us_products
# EBAY_LISTINGS_COVERAGE_INVENTORY_PRODUCT_ID_FIELD=
# EBAY_LISTINGS_COVERAGE_INVENTORY_SOURCE_FIELD=
# EBAY_LISTINGS_COVERAGE_INVENTORY_MARKETPLACE_FIELD=
# EBAY_LISTINGS_COVERAGE_INVENTORY_SOURCE_TERMS=
# EBAY_LISTINGS_COVERAGE_INVENTORY_MAX_HITS=
# EBAY_LISTINGS_COVERAGE_WRITE_MISSING_IDS=true
# EBAY_LISTINGS_COVERAGE_MISSING_IDS_DIR=tmp/ebay_listings_missing_ids

# ============================================================================
# Redis
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Blacklist API — strict .env-only (never in YAML)
# Used by `em-tools blacklist download`.
# ============================================================================
# BLACKLIST_API_ENDPOINT=https://api.everymarket.com
# BLACKLIST_API_PATH=/api/v1/blacklist
# BLACKLIST_API_TOKEN=

# ============================================================================
# Per-site (Spree storefront, partner APIs).
# Pattern: EM_TOOLS_SITE_<NAME>_{BASE_URL,ENDPOINT,TOKEN}. NAME is upcased; '-' -> '_'.
# ============================================================================
# EM_TOOLS_SITE_EXAMPLE_PARTNER_BASE_URL=https://partner.example.com
# EM_TOOLS_SITE_EXAMPLE_PARTNER_ENDPOINT=https://partner.example.com/api/v1
# EM_TOOLS_SITE_EXAMPLE_PARTNER_TOKEN=

# ============================================================================
# Google Cloud Translation (Basic API v2) — billing guards
# ============================================================================
# Hard cap on **new** billable source characters per Ruby process (required to enable).
# Cache hits do not count. Prefer a conservative number.
# EM_TRANSLATE_MAX_CHARS=50000
#
# Optional UTC-day cap persisted to state_path (best-effort under concurrency).
# EM_TRANSLATE_DAILY_CAP=200000
#
# EM_TRANSLATE_STATE_PATH=tmp/translate_usage_state.json
# EM_TRANSLATE_CACHE_DIR=tmp/translate_cache
# EM_TRANSLATE_MIN_INTERVAL=0.35     # seconds between API calls (throttle)
# EM_TRANSLATE_MAX_PER_REQUEST=4500  # batch size guard (< 5000 API limit)
# EM_TRANSLATE_MAX_RETRIES=3
#
# Auth: Application Default Credentials (GOOGLE_APPLICATION_CREDENTIALS) or API key:
# TRANSLATE_KEY=...   # or GOOGLE_CLOUD_KEY (see google-cloud-translate-v2)

# ============================================================================
# Settings loader overrides (rarely needed)
# ============================================================================
# EM_TOOLS_SETTINGS_PATH=/absolute/path/to/settings.yml
# EM_TOOLS_SKIP_SETTINGS_HYDRATE=1    # skip YAML -> ENV fallback at boot
