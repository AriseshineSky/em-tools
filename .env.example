# Copy to .env and fill in. Loaded by exe/em-tools and Rake when the `dotenv` gem is present.
# Precedence: values already in the environment win; then .env; then merged settings YAML
# (config/settings.yml if present, else examples/config/settings.example.yml) merged into ENV
# for keys that are still blank — see Em::Tools::SettingsHydrator.apply_if_blank!.

APP_ENV=development

# --- Elasticsearch (required for most ES CLI / Rake tasks) ---
ELASTICSEARCH_URL=http://localhost:9200

# Optional: point to a non-default YAML (absolute or cwd-relative after expand_path).
# EM_TOOLS_SETTINGS_PATH=/path/to/settings.yml

# Skip writing YAML defaults into ENV (e.g. in tests): EM_TOOLS_SKIP_SETTINGS_HYDRATE=1

# --- Redis (optional; used when you wire Redis clients to Em::Tools::Config.redis_url) ---
REDIS_URL=redis://localhost:6379/0

# --- Blacklist HTTP API (optional) ---
BLACKLIST_API_ENDPOINT=https://blacklist.example.com
BLACKLIST_API_PATH=/api/v1/check
BLACKLIST_API_KEY=
BLACKLIST_API_TOKEN=

# --- GCS (inventory / seeds) ---
GCS_SERVICE_ACCOUNT_PATH=/path/to/gcs-service-account.json

# --- Per-site overrides (match names under settings.yml "sites") ---
# EM_TOOLS_SITE_EXAMPLE_PARTNER_BASE_URL=https://partner.example.com
# EM_TOOLS_SITE_EXAMPLE_PARTNER_ENDPOINT=https://partner.example.com/api/v1
# EM_TOOLS_SITE_EXAMPLE_PARTNER_TOKEN=
