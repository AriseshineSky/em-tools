# em-tools — daily full inventory sync (cron + shell script)
#
# Install:
#   chmod +x /home/Admin/src/em-tools/scripts/inventory-sync.sh
#   sudo cp schedule/cron.inventory-sync.example /etc/cron.d/em-tools-inventory-sync
#   sudo vim /etc/cron.d/em-tools-inventory-sync    # edit USER and paths
#   sudo mkdir -p /home/Admin/src/em-tools/log
#   sudo systemctl reload cron
#
# User crontab (crontab -e) — no USER column:
#   30 3 * * * /home/Admin/src/em-tools/scripts/inventory-sync.sh >> /home/Admin/src/em-tools/log/inventory-sync.log 2>&1
#
# prune_obsolete: set in config/settings.yml (not .env INVENTORY_PRUNE_OBSOLETE)

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
MAILTO=""

# --- edit USER and absolute script path ---
30 3 * * *  Admin  /home/Admin/src/em-tools/scripts/inventory-sync.sh >> /home/Admin/src/em-tools/log/inventory-sync.log 2>&1
