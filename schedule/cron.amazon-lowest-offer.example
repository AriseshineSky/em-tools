# em-tools — Amazon lowest-offer snapshot only (install at /etc/cron.d/em-tools-amazon-lowest-offer).
#
# Format:  m h dom mon dow USER  COMMAND
# Edit USER, REPO, and EM_TOOLS_BUNDLE to match your host.
#
# Install:
#   chmod +x /home/Admin/src/em-tools/scripts/amazon-lowest-offer-snapshot.sh
#   sudo cp schedule/cron.amazon-lowest-offer.example /etc/cron.d/em-tools-amazon-lowest-offer
#   sudo vim /etc/cron.d/em-tools-amazon-lowest-offer
#   sudo mkdir -p /home/Admin/src/em-tools/log
#   sudo systemctl reload cron

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
MAILTO=""

# 04:00 daily — download ad-report seeds from GCS + publish lowest-offer coverage snapshot.
0 4 * * *  Admin  EM_TOOLS_BUNDLE=/home/Admin/.rbenv/shims/bundle /home/Admin/src/em-tools/scripts/amazon-lowest-offer-snapshot.sh >> /home/Admin/src/em-tools/log/em-tools.lowest-offer.log 2>&1
