# em-tools — hourly user1_amz_asins -> amz_asins_<mp> (all marketplaces)
#
# Production (c1002us / 35.202.167.107):
#   ELASTICSEARCH_URL + DATA_ELASTICSEARCH_URL in /home/Admin/src/em-tools/.env
#
# Install:
#   sudo cp schedule/cron.amazon-sync-user1-amz-asins.example /etc/cron.d/em-tools-amz-asins-sync
#   sudo chmod 644 /etc/cron.d/em-tools-amz-asins-sync
#   sudo systemctl restart cron

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
MAILTO=""

# Every hour at :15 — all marketplaces, last 2 hours (overlap with prior run).
15 * * * *  Admin  EM_TOOLS_BUNDLE=/home/Admin/.rbenv/shims/bundle /home/Admin/src/em-tools/scripts/amazon-sync-user1-amz-asins.sh --since-hours 2 >> /home/Admin/src/em-tools/log/amazon-sync-user1-amz-asins.log 2>&1
