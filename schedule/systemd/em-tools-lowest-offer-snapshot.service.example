# em-tools — Amazon lowest-offer coverage snapshot (download seeds + publish).

[Unit]
Description=em-tools Amazon lowest-offer coverage snapshot
After=network-online.target em-tools-inventory-sync.service
Wants=network-online.target

[Service]
Type=oneshot
User=sky
Group=sky
WorkingDirectory=/home/sky/src/em-tools

EnvironmentFile=-/home/sky/src/em-tools/.env

ExecStart=/usr/bin/bash -lc 'export EM_TOOLS_BUNDLE=/home/sky/.rbenv/shims/bundle; cd /home/sky/src/em-tools && bin/amazon-lowest-offer-snapshot'

TimeoutStartSec=10800
Nice=10

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
